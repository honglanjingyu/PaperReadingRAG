# 远程PDF解析配置 https://mineru.net/
ENABLE_REMOTE_PARSE=true
PARSE_API_TOKEN=

# ========== 通用 API Key（可选，作为后备） ==========
# 优先采用专用apikey
MODEL_API_KEY=

# ========== Embedding 配置 ==========
# remote 或 local 如果Embedding、Rerank、LLM是同一个apikey,则专用的置空,只需设置MODEL_API_KEY
EMBEDDING_TYPE=remote
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1024
LOCAL_EMBEDDING_PATH=/path/to/local/embedding/model
LOCAL_EMBEDDING_MODEL=bge-small-zh

# ========== Rerank 配置 ==========
# auto, remote, local, vector
RERANK_TYPE=remote
RERANK_MODEL=gte-rerank
RERANK_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank
RERANK_API_KEY=
LOCAL_RERANK_PATH=/path/to/local/rerank/model
LOCAL_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ========== LLM 配置 ==========
# remote 或 local
LLM_TYPE=remote
LLM_MODEL=qwen-turbo
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=
LOCAL_LLM_PATH=/path/to/local/llm/model

LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# ========== 向量存储配置 ==========
# 向量存储类型: elasticsearch 或 milvus
VECTOR_STORE_TYPE=milvus
# elasticsearch
# VECTOR_STORE_HOST=localhost
# VECTOR_STORE_PORT=9200
# VECTOR_STORE_USER=elastic
# VECTOR_STORE_PASSWORD=infini_rag_flow
# milvus
VECTOR_STORE_HOST=172.20.48.1
VECTOR_STORE_PORT=19530
VECTOR_STORE_USER=
VECTOR_STORE_PASSWORD=

# 运行设备: cpu 或 cuda
EMBEDDING_DEVICE=cuda

# 批量处理大小
EMBEDDING_BATCH_SIZE=32

# 混合检索权重 向量检索权重和关键词检索权重
HYBRID_VECTOR_WEIGHT=0.6
HYBRID_KEYWORD_WEIGHT=0.4

# 检索参数 Top-K 召回数量和相似度阈值
SIMILARITY_TOP_K=5
SIMILARITY_THRESHOLD=0.3