# ==================== Embedding 配置 ====================
# 选择使用的模型类型: remote 或 local
EMBEDDING_TYPE=remote

# ==================== 远程API配置 ====================
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIMENSIONS=1024

# ==================== 本地模型配置 ====================
# 本地模型名称: bge-small-zh, bge-base-zh, bge-large-zh, m3e-base, text2vec-base
LOCAL_EMBEDDING_MODEL=bge-small-zh

# 本地模型路径（可选，不指定则使用预设路径）
LOCAL_EMBEDDING_PATH=E:\HF_HOME\hub\models--BAAI--bge-small-zh-v1.5\snapshots\7999e1d3359715c523056ef9478215996d62a620

# 运行设备: cpu 或 cuda
EMBEDDING_DEVICE=cuda

# 批量处理大小
EMBEDDING_BATCH_SIZE=32